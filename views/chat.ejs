<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Chat</title>
    <style>
        body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0f172a;
}

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100dvh;
}

.chat-header {
  background: #1e293b;
  color: white;
  padding: 12px 16px;
  border-bottom: 1px solid #334155;
}

.chat-header .user {
  display: flex;
  align-items: center;
  gap: 10px;
}

.avatar {
  width: 40px;
  height: 40px;
  background: #3b82f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-messages {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.message {
  max-width: 60%;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 14px;
}

.sent {
  background: #22c55e;
  align-self: flex-end;
  color: white;
}

.received {
  background: #334155;
  align-self: flex-start;
  color: white;
}

.chat-input {
  display: flex;
  padding: 10px;
  background: #1e293b;
  border-top: 1px solid #334155;
}

.chat-input input {
  flex: 1;
  padding: 10px;
  border-radius: 8px;
  border: none;
  outline: none;
}

.chat-input button {
  margin-left: 10px;
  padding: 10px 16px;
  border: none;
  background: #22c55e;
  color: white;
  border-radius: 8px;
  cursor: pointer;
}
    </style>
</head>
<body>
    <div class="chat-container">

  <div class="chat-header">
    <div class="user">
        <div> <a href="/" style="text-decoration: none;justify-content: center;color:antiquewhite" ><h2> ⬅️ </h2></a></div>
      <div class="avatar">U</div>
      <div>
        <h3><%= locals.user.name %></h3>
        <p class="status">Online</p>
      </div>
    </div>
  </div>

  <div class="chat-messages" id="chatMessages">
    <% allMessages.forEach(message => { %>
     <% if (message.sender.toString() === user._id.toString()) { %>
      <div class="message received"><%= message.content %></div>
     <% } else { %>
        <div class="message sent"><%= message.content %></div>
        <%} %>
    <% }) %>
  </div>

  <div class="chat-input">
    <form action="/chat/<%= locals.user._id %>" method="post">
        <input
            type="text",
            name="content",
            placeholder="Enter your Message..."
            id="message"
        >
        <button type="submit" id="btn">Send</button>
    </form>
  </div>

</div>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const senderId = "<%= userId%>";
        const receiverId = "<%=user._id%>";
        socket.emit("join", senderId);
        const messageInput = document.getElementById("message");
        const btn = document.getElementById("btn");
        const chatMessages = document.getElementById("chatMessages");
        btn.addEventListener("click", (e) => {
            const message = messageInput.value;
            console.log("Message: ",messageInput);
            socket.emit("message", ({senderId, receiverId, message })); 
            
        })
        socket.on("receivedMessage", ({sender,receiver, message}) => {
          if(senderId === sender || receiverId === receiver){
            const div = document.createElement("div");
            if(sender === senderId){
              div.className = "message sent"
            }
            else{
              div.className = "message received"
            }
            div.innerText = message;
            chatMessages.appendChild(div);
          }
            chatMessages.scrollTo({
  top: chatMessages.scrollHeight,
  behavior: "smooth"
});
        })
        window.onload = () => {
  chatMessages.scrollTop = chatMessages.scrollHeight;
};
    </script>
</body>
</html>